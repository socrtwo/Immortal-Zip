{
  "name": "immortal-unzip",
  "version": "1.0.0",
  "description": "Immortal Unzip — Fault-Tolerant ZIP Extractor with Repair Mode",
  "main": "main.js",
  "author": {
    "name": "socrtwo",
    "email": "socrtwo@s2services.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/socrtwo/Immortal-Zip.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux",
    "build:appimage": "electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "build:rpm": "electron-builder --linux rpm"
  },
  "build": {
    "appId": "com.socrtwo.immortalunzip",
    "productName": "Immortal Unzip",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "immortal-unzip.html"
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] },
        { "target": "rpm",      "arch": ["x64"] }
      ],
      "icon": "icon.png",
      "category": "Utility",
      "description": "Fault-tolerant ZIP extractor with repair mode"
    },
    "fileAssociations": [
      { "ext": "zip",  "name": "ZIP Archive",   "role": "Editor", "mimeType": "application/zip" },
      { "ext": "jar",  "name": "JAR Archive",   "role": "Editor", "mimeType": "application/java-archive" },
      { "ext": "docx", "name": "Word Document", "role": "Editor", "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document" },
      { "ext": "xlsx", "name": "Excel Workbook","role": "Editor", "mimeType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" },
      { "ext": "pptx", "name": "PowerPoint",    "role": "Editor", "mimeType": "application/vnd.openxmlformats-officedocument.presentationml.presentation" },
      { "ext": "epub", "name": "EPUB Book",     "role": "Editor", "mimeType": "application/epub+zip" }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
